{
  "name": "@dorkos/monorepo",
  "private": true,
  "version": "0.45.1",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "dotenv -- turbo dev --filter=!@dorkos/desktop",
    "dev:desktop": "dotenv -- turbo dev --filter=@dorkos/desktop",
    "dev:dogfood": "concurrently --names preview,cockpit --prefix-colors cyan,magenta --kill-others \"pnpm dev\" \"pnpm cli:dev\"",
    "build": "dotenv -- turbo build",
    "test": "dotenv -- turbo test",
    "typecheck": "dotenv -- turbo typecheck",
    "verify": "turbo run typecheck lint --affected && turbo run test --affected -- --run",
    "start": "dotenv -- pnpm --filter=@dorkos/server run start",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "docs:export-api": "tsx scripts/export-openapi.ts",
    "test:browser": "dotenv -- turbo run e2e --filter=@dorkos/e2e --only",
    "test:browser:ui": "dotenv -- turbo run e2e:ui --filter=@dorkos/e2e --only",
    "prepare": "lefthook install",
    "smoke:docker": "pnpm --filter=dorkos run build && cd packages/cli && pnpm pack --pack-destination ../../ && cd ../.. && docker build -t dorkos-smoke . && docker run --rm dorkos-smoke",
    "smoke:integration": "pnpm --filter=dorkos run build && cd packages/cli && pnpm pack --pack-destination ../../ && cd ../.. && docker build -f Dockerfile.integration -t dorkos-integration . && docker run --rm dorkos-integration",
    "smoke:npm": "docker build -f Dockerfile.integration --build-arg INSTALL_MODE=npm -t dorkos-integration:npm . && docker run --rm dorkos-integration:npm",
    "docker:build": "pnpm --filter=dorkos run build && cd packages/cli && pnpm pack --pack-destination ../../ && cd ../.. && docker build -f Dockerfile.run -t dorkos .",
    "docker:run": "docker run --rm -p 4242:4242 dorkos",
    "publish:cli": "pnpm publish --filter=dorkos",
    "cli:dev": "pnpm --filter=./packages/cli run build && node packages/cli/dist/bin/cli.js"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@dorkos/eslint-config": "workspace:*",
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "knip": "^6.20.0",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "@anthropic-ai/claude-agent-sdk": "0.3.177",
      "@types/node": "^24",
      "@anthropic-ai/sdk": "0.102.0",
      "@modelcontextprotocol/sdk": "1.29.0",
      "lucide-react": "1.21.0",
      "@vitejs/plugin-react": "5.1.4",
      "drizzle-orm": "0.45.2",
      "eslint-plugin-react-hooks": "7.0.1",
      "lodash-es": "^4.18.1",
      "dompurify": "^3.4.9",
      "hono": "^4.12.25",
      "@hono/node-server": "^1.19.14",
      "esbuild": "^0.25.0",
      "vite@7": "7.3.6",
      "axios": "^1.15.1",
      "fast-uri": "^3.1.1",
      "undici": "^7.28.0",
      "form-data": "^4.0.6",
      "ws": "^8.21.0"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "ffmpeg-static",
      "electron",
      "lefthook",
      "node-pty",
      "sharp",
      "protobufjs",
      "unrs-resolver",
      "core-js"
    ],
    "ignoredBuiltDependencies": [
      "electron-winstaller"
    ]
  }
}
