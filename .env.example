# DorkOS Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Server port
DORKOS_PORT=4242

# Default working directory for new sessions
# DORKOS_DEFAULT_CWD=~/projects

# Directory access boundary (security: restricts file browsing to this path)
# DORKOS_BOUNDARY=~

# Log level: 0=Fatal, 1=Error, 2=Warn, 3=Info (default), 4=Debug, 5=Trace
# DORKOS_LOG_LEVEL=3

# Config/storage directory
# Default in production (or via CLI):  ~/.dork
# Default in dev (NODE_ENV != production): .temp/.dork  (project-local, gitignored)
# Override in any environment:
# DORK_HOME=/custom/path

# Pulse scheduler — enabled by default; set false to disable
# DORKOS_PULSE_ENABLED=false

# Relay inter-agent message bus — enabled by default; set false to disable
# DORKOS_RELAY_ENABLED=false

# Tunnel configuration (optional)
# TUNNEL_ENABLED=true
# NGROK_AUTHTOKEN=your-token-here
# TUNNEL_AUTH=user:password
# TUNNEL_DOMAIN=your-domain.ngrok-free.app
# TUNNEL_PORT=4242

# MCP Server — optional API key for external agent authentication
# Required when using tunnel (ngrok) for remote access.
# Generate a random key: openssl rand -hex 32
# MCP_API_KEY=your-api-key-here

# Vite dev server port (client only; proxies /api to DORKOS_PORT)
# VITE_PORT=4241

# Marketing site analytics (apps/web only)
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Override version for testing upgrade notifications in dev mode.
# When set, dev detection is bypassed and this value is used as the current version.
# Example: DORKOS_VERSION_OVERRIDE=0.1.0 makes the UI show upgrade available for any version > 0.1.0
# DORKOS_VERSION_OVERRIDE=
