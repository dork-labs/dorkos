{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "VITEST_RETRY",
    "CLIENT_DIST_PATH",
    "DO_NOT_TRACK",
    "DORK_HOME",
    "DORKOS_A2A_ENABLED",
    "DORKOS_ACTIVITY_RETENTION_DAYS",
    "DORKOS_BOUNDARY",
    "DORKOS_CORS_ORIGIN",
    "DORKOS_DEFAULT_CWD",
    "DORKOS_LOG_LEVEL",
    "DORKOS_PORT",
    "DORKOS_TASKS_ENABLED",
    "DORKOS_TELEMETRY_DEBUG",
    "DORKOS_TELEMETRY_DISABLED",
    "DORKOS_TEST_RUNTIME",
    "DORKOS_TEST_RUNTIME_SECONDARY",
    "DORKOS_RELAY_ENABLED",
    "DORKOS_VERSION_OVERRIDE",
    "MCP_API_KEY",
    "NGROK_AUTHTOKEN",
    "OTEL_*",
    "SITE_PORT",
    "TUNNEL_AUTH",
    "TUNNEL_DOMAIN",
    "TUNNEL_ENABLED",
    "TUNNEL_PORT",
    "VITE_PORT",
    "ELECTRON_VERSION"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["generate:api-docs", "^build"],
      "outputs": ["dist/**", "dist-server/**", "dist-obsidian/**", ".next/**"],
      // VERCEL_ENV is in the cache key because the site build's post-build
      // sourcemap step behaves differently per environment (preview skips the
      // PostHog upload). Without it, a preview build could populate a shared
      // remote-cache entry that a later production build consumes as a HIT,
      // skipping the upload so production maps never reach PostHog. Keeping it
      // here makes preview and production hash to different keys. We do NOT add
      // VERCEL_GIT_COMMIT_SHA: it would bust the cache every commit, and it is
      // unnecessary because PostHog symbolication matches on the content-derived
      // chunkId, so any prod build with identical content already has its maps.
      "env": ["NODE_ENV", "VITE_*", "NEXT_PUBLIC_*", "POSTHOG_*", "VERCEL_ENV"]
    },
    "generate:api-docs": {
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "cache": true
    },
    "pack": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "cache": false
    },
    "e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "passThroughEnv": [
        "PLAYWRIGHT_BROWSERS_PATH",
        "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD",
        "CI",
        "PWDEBUG",
        "ANTHROPIC_API_KEY"
      ]
    },
    "e2e:ui": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "inputs": ["src/schema/**/*.ts", "drizzle.config.ts"],
      "outputs": ["drizzle/**"],
      "cache": true
    },
    "db:check": {
      "inputs": ["src/schema/**/*.ts", "drizzle.config.ts"],
      "cache": false
    },
    "dist": {
      "dependsOn": ["build"],
      "outputs": ["release/**"],
      "cache": false,
      "env": [
        "APPLE_API_KEY",
        "APPLE_API_KEY_ID",
        "APPLE_API_ISSUER",
        "CSC_LINK",
        "CSC_KEY_PASSWORD",
        "GH_TOKEN"
      ]
    }
  }
}
