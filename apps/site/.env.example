# Database — Neon Postgres. The site uses @neondatabase/serverless, so a SQLite
# `file:` URL will NOT work; DATABASE_URL must be a Postgres connection string.
# Easiest local setup: link the project, then `vercel env pull apps/site/.env.local`
# to fetch the Neon integration's connection string. Or set one manually (use a
# Neon *dev branch* for local work, never your production database):
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Authentication — Better Auth, the DorkOS *account* cloud identity (P2).
# For production, generate a secure 32+ character secret:
#   Option 1: openssl rand -base64 32
#   Option 2: npx @better-auth/cli secret
# Docs: https://www.better-auth.com/docs/installation#set-environment-variables
BETTER_AUTH_SECRET="dev-only-insecure-secret-do-not-use-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Social sign-in (GitHub + Google). Leave empty to disable a provider; the
# providers still register but won't complete OAuth without credentials.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend — transactional email for DorkOS account verification + password reset.
# Required to actually send email; sending throws a clear error when unset.
# RESEND_FROM must be a verified sender on your Resend domain.
RESEND_API_KEY=""
RESEND_FROM="DorkOS <onboarding@resend.dev>"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# PostHog Analytics
# Get your API key from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY="your_posthog_project_api_key_here"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
