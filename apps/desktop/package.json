{
  "name": "@dorkos/desktop",
  "version": "0.1.0",
  "description": "DorkOS desktop app — mission control for your coding agents",
  "author": "Dorian Collier",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@dorkos/db": "workspace:*",
    "@dorkos/server": "workspace:*",
    "@dorkos/shared": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@dorkos/client": "workspace:*",
    "@dorkos/eslint-config": "workspace:*",
    "@dorkos/typescript-config": "workspace:*",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "5.1.4",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
