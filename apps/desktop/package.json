{
  "name": "@dorkos/desktop",
  "version": "0.54.0",
  "description": "DorkOS desktop app — mission control for your coding agents",
  "author": "Dorian Collier",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && tsx scripts/build-server.ts",
    "preview": "electron-vite preview",
    "pack": "tsx scripts/rebuild-natives.ts && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "tsx scripts/rebuild-natives.ts && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk-darwin-arm64": "0.3.177",
    "@anthropic-ai/claude-agent-sdk-win32-x64": "0.3.177"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.177",
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@dorkos/db": "workspace:*",
    "@dorkos/server": "workspace:*",
    "@dorkos/shared": "workspace:*",
    "@ngrok/ngrok": "^1.7.0",
    "@openai/codex": "0.144.1",
    "@openai/codex-sdk": "~0.144.1",
    "@opencode-ai/sdk": "^1.17.13",
    "@scalar/express-api-reference": "^0.9.8",
    "better-sqlite3": "^12.11.1",
    "conf": "^15.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "node-pty": "^1.1.0",
    "uuid": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dorkos/client": "workspace:*",
    "@dorkos/eslint-config": "workspace:*",
    "@dorkos/typescript-config": "workspace:*",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "5.1.4",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
