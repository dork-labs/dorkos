{
  "name": "@dorkos/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./services/runtimes/claude-code": "./src/services/runtimes/claude-code/index.ts",
    "./services/session": "./src/services/session/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:tunnel": "TUNNEL_ENABLED=true TUNNEL_PORT=3000 tsx watch src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/core-extensions','dist/core-extensions',{recursive:true})\"",
    "start": "NODE_ENV=production node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.177",
    "@anthropic-ai/sdk": "^0.102.0",
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@better-auth/api-key": "^1.6.23",
    "@dorkos/a2a-gateway": "workspace:*",
    "@dorkos/db": "workspace:*",
    "@dorkos/extension-api": "workspace:*",
    "@dorkos/harness": "workspace:*",
    "@dorkos/marketplace": "workspace:*",
    "@dorkos/mesh": "workspace:*",
    "@dorkos/relay": "workspace:*",
    "@dorkos/shared": "workspace:*",
    "@dorkos/skills": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@ngrok/ngrok": "^1.7.0",
    "@openai/codex-sdk": "~0.142.5",
    "@opencode-ai/sdk": "^1.17.13",
    "@scalar/express-api-reference": "^0.9.8",
    "better-auth": "^1.6",
    "chokidar": "^5.0.0",
    "conf": "^15.1.0",
    "consola": "^3.4.2",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.6",
    "croner": "^10.0.1",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "giget": "^3.3.0",
    "gray-matter": "^4.0.3",
    "multer": "^2.2.0",
    "semver": "^7.8.5",
    "ulidx": "^2.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dorkos/eslint-config": "workspace:*",
    "@dorkos/test-utils": "workspace:*",
    "@dorkos/typescript-config": "workspace:*",
    "@types/cookie-session": "^2.0.49",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^24",
    "@types/semver": "^7.7.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^2.1.9",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
