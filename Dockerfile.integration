# DorkOS Full Integration Test
# Installs dorkos (from tarball or npm), starts the server, and validates
# API endpoints + client SPA serving.
#
# Usage (local tarball):
#   docker build -f Dockerfile.integration -t dorkos-integration .
#   docker run --rm dorkos-integration
#
# Usage (published npm package):
#   docker build -f Dockerfile.integration \
#     --build-arg INSTALL_MODE=npm --build-arg DORKOS_VERSION=latest \
#     -t dorkos-integration:npm .
#   docker run --rm dorkos-integration:npm

ARG NODE_VERSION=24
FROM node:${NODE_VERSION}-slim

# curl needed for health checks in test script
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      python3 build-essential libsqlite3-dev curl && \
    rm -rf /var/lib/apt/lists/*

# Mock Claude CLI so post-install check succeeds without a real install
ARG MOCK_CLAUDE=true
RUN if [ "$MOCK_CLAUDE" = "true" ]; then \
      printf '#!/bin/sh\necho "claude mock 1.0.0"\n' > /usr/local/bin/claude && \
      chmod +x /usr/local/bin/claude; \
    fi

# Install mode: "tarball" (local build) or "npm" (published package)
ARG INSTALL_MODE=tarball
ARG DORKOS_VERSION=latest

# Copy tarball (only used in tarball mode, ignored in npm mode)
COPY dorkos-*.tgz /tmp/

# Install based on mode
RUN if [ "$INSTALL_MODE" = "tarball" ]; then \
      npm install -g /tmp/dorkos-*.tgz; \
    else \
      npm install -g "dorkos@${DORKOS_VERSION}"; \
    fi && \
    rm -f /tmp/dorkos-*.tgz

# Bind to all interfaces (localhost resolves to ::1 in containers).
# The container owns the network boundary, so opt out of the non-loopback bind
# guard (accounts-and-auth task 1.3) that would otherwise refuse to start.
ENV DORKOS_HOST=0.0.0.0
ENV DORKOS_ALLOW_INSECURE_BIND=true

# Copy test runner
COPY scripts/smoke-test.sh /usr/local/bin/smoke-test
RUN chmod +x /usr/local/bin/smoke-test

# Run init (creates ~/.dork/config.json) then full integration tests
CMD dorkos init --yes && smoke-test
