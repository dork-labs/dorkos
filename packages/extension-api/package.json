{
  "name": "@dorkos/extension-api",
  "version": "0.1.0",
  "description": "Public API contract and manifest schema for DorkOS extensions; authors type against this package while the host provides the implementation.",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./src/server-extension-api.ts",
      "default": "./dist/server-extension-api.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@dorkos/shared": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dorkos/eslint-config": "workspace:*",
    "@dorkos/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "vitest": "^4.1.4"
  }
}
