{
  "name": "@dorkos/flow",
  "version": "0.0.0",
  "description": "Typed core of the /flow engine — the authoritative Zod config schema plus the work-item model, calibration ladder, dispatch policy, gates, recovery, and evidence selection.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "lint": "eslint src/ scripts/",
    "generate:schema": "tsx scripts/generate-config-schema.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./config-schema": {
      "types": "./src/config-schema.ts",
      "default": "./dist/config-schema.js"
    }
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dorkos/eslint-config": "workspace:*",
    "@dorkos/typescript-config": "workspace:*",
    "@types/node": "^24",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "prettier": "^3.8.3",
    "tsx": "^4.20.3",
    "vitest": "^3.2.6"
  }
}
