{
  "name": "@dorkos/relay",
  "version": "0.0.0",
  "description": "Foundational inter-agent message bus — NATS-style subject matching, Maildir persistence, SQLite indexing, and pluggable channel adapters.",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "build": "tsc && for d in src/adapters/*/docs; do [ -d \"$d\" ] && t=$(echo \"$d\" | sed 's|src/|dist/|') && mkdir -p \"$t\" && cp \"$d\"/*.md \"$t/\"; done",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@chat-adapter/telegram": "^4.26.0",
    "@dorkos/db": "workspace:*",
    "@dorkos/shared": "workspace:*",
    "@grammyjs/auto-retry": "^2.0.2",
    "@slack/bolt": "^4.7.0",
    "@slack/web-api": "^7.15.1",
    "chat": "^4.26.0",
    "chokidar": "^5.0.0",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.42.0",
    "slackify-markdown": "^5.0.0",
    "ulidx": "^2.4.1"
  },
  "devDependencies": {
    "@dorkos/eslint-config": "workspace:*",
    "@dorkos/typescript-config": "workspace:*",
    "vitest": "^4.1.4"
  }
}
