{
  "name": "@dorkos/shared",
  "version": "0.0.0",
  "description": "Shared Zod schemas, TypeScript types, and the AgentRuntime and Transport contracts used across every DorkOS app and package.",
  "private": true,
  "type": "module",
  "exports": {
    "./schemas": {
      "types": "./src/schemas.ts",
      "default": "./dist/schemas.js"
    },
    "./transport": {
      "types": "./src/transport.ts",
      "default": "./dist/transport.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./dist/types.js"
    },
    "./constants": {
      "types": "./src/constants.ts",
      "default": "./dist/constants.js"
    },
    "./config-schema": {
      "types": "./src/config-schema.ts",
      "default": "./dist/config-schema.js"
    },
    "./relay-schemas": {
      "types": "./src/relay-schemas.ts",
      "default": "./dist/relay-schemas.js"
    },
    "./mesh-schemas": {
      "types": "./src/mesh-schemas.ts",
      "default": "./dist/mesh-schemas.js"
    },
    "./manifest": {
      "types": "./src/manifest.ts",
      "default": "./dist/manifest.js"
    },
    "./logger": {
      "types": "./src/logger.ts",
      "default": "./dist/logger.js"
    },
    "./agent-runtime": {
      "types": "./src/agent-runtime.ts",
      "default": "./dist/agent-runtime.js"
    },
    "./workspace": {
      "types": "./src/workspace.ts",
      "default": "./dist/workspace.js"
    },
    "./additional-context": {
      "types": "./src/additional-context.ts",
      "default": "./dist/additional-context.js"
    },
    "./convention-files": {
      "types": "./src/convention-files.ts",
      "default": "./dist/convention-files.js"
    },
    "./convention-files-io": {
      "types": "./src/convention-files-io.ts",
      "default": "./dist/convention-files-io.js"
    },
    "./trait-renderer": {
      "types": "./src/trait-renderer.ts",
      "default": "./dist/trait-renderer.js"
    },
    "./validation": {
      "types": "./src/validation.ts",
      "default": "./dist/validation.js"
    },
    "./template-catalog": {
      "types": "./src/template-catalog.ts",
      "default": "./dist/template-catalog.js"
    },
    "./dorkbot-templates": {
      "types": "./src/dorkbot-templates.ts",
      "default": "./dist/dorkbot-templates.js"
    },
    "./extension-secrets": {
      "types": "./src/extension-secrets.ts",
      "default": "./dist/extension-secrets.js"
    },
    "./extension-settings": {
      "types": "./src/extension-settings.ts",
      "default": "./dist/extension-settings.js"
    },
    "./activity-schemas": {
      "types": "./src/activity-schemas.ts",
      "default": "./dist/activity-schemas.js"
    },
    "./marketplace-schemas": {
      "types": "./src/marketplace-schemas.ts",
      "default": "./dist/marketplace-schemas.js"
    },
    "./cloud-schemas": {
      "types": "./src/cloud-schemas.ts",
      "default": "./dist/cloud-schemas.js"
    },
    "./session-stream": {
      "types": "./src/session-stream.ts",
      "default": "./dist/session-stream.js"
    },
    "./runtime-connect": {
      "types": "./src/runtime-connect.ts",
      "default": "./dist/runtime-connect.js"
    },
    "./ui-widget": {
      "types": "./src/ui-widget.ts",
      "default": "./dist/ui-widget.js"
    },
    "./viewer-registry": {
      "types": "./src/viewer-registry.ts",
      "default": "./dist/viewer-registry.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dorkos/eslint-config": "workspace:*",
    "@dorkos/typescript-config": "workspace:*",
    "@types/node": "^24",
    "vitest": "^4.1.9"
  }
}
