{
  "name": "@dorkos/db",
  "version": "0.0.0",
  "description": "Drizzle ORM schemas and the SQLite layer backing DorkOS — agents, mesh, relay, tasks, sessions, activity, and A2A.",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:check": "drizzle-kit generate --config drizzle.config.ts && git diff --exit-code drizzle/",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "ulidx": "^2.4.1"
  },
  "devDependencies": {
    "@dorkos/eslint-config": "workspace:*",
    "@dorkos/typescript-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
