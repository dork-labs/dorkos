# .gtrconfig — team-shared git-worktree-runner settings (gitconfig syntax).
# Docs: https://github.com/coderabbitai/git-worktree-runner/blob/main/docs/configuration.md
#
# Precedence: .git/config (local) > .gtrconfig (this file) > ~/.gitconfig (global)
#
# NOTE: Section names here are UNPREFIXED (`[copy]`, not `[gtr "copy"]`).
# gtr maps these to `gtr.*` git config keys internally via lib/config.sh.
# Using `[gtr "..."]` sections silently fails for `defaults.editor` etc.

[worktrees]
    # Worktrees live under the future DorkOS workspace root (<root>/<project>/<key>)
    # so the eventual server-managed WorkspaceManager inherits them in place.
    # See research/20260611_workspace_strategy_runtimes_symphony.md.
    dir = ~/.dork/workspaces/core

[copy]
    # Gitignored files copied from the main repo into each new worktree.
    # .env.example and .mcp.json.example are tracked by git, so they don't
    # need to be listed — they appear in every worktree automatically.
    include = .env
    include = .mcp.json

    # Copy the entire .vercel/ directory (project.json + README.txt) so
    # `vercel` CLI commands work in worktrees without re-linking.
    includeDirs = .vercel

[hooks]
    # Run after worktree creation, in order.
    # 1. pnpm install — fast because pnpm reuses its global content-addressable
    #    store; do NOT add `node_modules` to includeDirs (would corrupt links).
    # 2. fumadocs-mdx — generates apps/site/.source/ types; without them
    #    @dorkos/site#typecheck fails in a fresh worktree (pre-commit hook).
    # 3. turbo build (packages/* only, ~7s) — package.json `exports` maps each
    #    internal package's runtime entry to `dist/*.js` (types resolve straight
    #    to `src/*.ts` via the `types` condition, so `tsc` is unaffected, but
    #    Vite/vitest module resolution needs the built JS). Without this, a
    #    fresh worktree's bare `pnpm vitest run <file>` fails to resolve
    #    `@dorkos/*` imports — vitest auto-discovers every workspace project,
    #    so even a single-file run loads apps/client's vite.config.ts, which
    #    needs `@dorkos/shared/dist` (DOR-117). Scoped to packages/* (skips
    #    apps/* and packages/cli, which esbuild-bundles standalone and nothing
    #    else depends on) — turbo's `^build` dependency graph still builds
    #    everything those packages need transitively. Packages without a
    #    `dist`-based export (db, test-utils, icons, ...) have no build script
    #    and are skipped instantly.
    # 4. worktree-setup.sh — patches .env with worktree-unique DORKOS_PORT,
    #    VITE_PORT, and SITE_PORT so parallel `pnpm dev` instances don't collide.
    postCreate = pnpm install
    postCreate = pnpm --filter @dorkos/site exec fumadocs-mdx
    postCreate = pnpm exec turbo build --filter='./packages/*' --filter='!dorkos'
    postCreate = .claude/scripts/worktree-setup.sh

[defaults]
    editor = cursor
    ai = claude
