# Dependencies
node_modules/

# pnpm workspace bin symlinks
packages/cli/bin/

# Build outputs
dist/
dist-server/
dist-obsidian/
*.tsbuildinfo
*.tgz
.source/

# Generated docs (openapi.json is committed for Vercel builds)

# Turborepo
.turbo/

# Test & coverage
coverage/
test-results/

# Capture media library — raw recordings are heavy and regenerable; only the
# layout README is committed (see apps/e2e/capture/library/README.md)
apps/e2e/capture/library/*
!apps/e2e/capture/library/README.md

# Environment & secrets
.env
.mcp.json

# Tooling caches
.eslintcache
*.timestamp-*
.playwright-mcp

# yalc — local package co-dev overlay (e.g. in-flight blintz changes)
.yalc/
yalc.lock

# OS files
.DS_Store

# Project working files
.plan
.scratch/
.temp
# Transient lock that suppresses the changelog-populator post-commit hook
.claude/.changelog-populator.lock
.vercel
.worktrees/
.superpowers/
mockups/background-agent-indicator.html
mockups/running-figure-drafts.html
mockups/running-figure-final.html
mockups/running-figure-transitions.html
mockups/running-figure-v2.html
mockups/running-figure-v3.html
.dork/visual-companion/
.dork/flow/
# Marketplace-installed plugins + their ephemeral harness projections (DOR-173).
# Kept in sync with EPHEMERAL_GITIGNORE_PATTERNS in @dorkos/harness.
.dork/plugins/
.agents/skills/*__*
.codex/hooks.json
.cursor/hooks.json
.github/hooks/copilot-hooks.json
# Transient install-transaction target backups (ADR-0304): reaped on success,
# left on disk only after a hard crash mid-activate.
*.dorkos-bak-*
